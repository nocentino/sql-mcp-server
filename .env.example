# SQL Server Configuration
SA_PASSWORD=YourStrongPasswordHere!
ACCEPT_EULA=Y

# Database Configuration
SQL_DATABASE=ProductsDB

# SQL Server DBA MCP Server — instance configuration
# INSTANCES is a JSON array of named SQL Server connections.
# The "SqlServer1" instance is used when no instance_name is specified.
# Call the list_instances tool to discover all available instances.
INSTANCES='[
  {
    "name":     "SqlServer1",
    "host":     "sqlserver1",
    "port":     1433,
    "user":     "dba_monitor",
    "password": "YourMonitorPasswordHere!"
  },
  {
    "name":     "SqlServer2",
    "host":     "sqlserver2",
    "port":     1433,
    "user":     "dba_monitor",
    "password": "YourMonitorPasswordHere!"
  }
]'
